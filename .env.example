# Copiar a .env y ajustar.
# data/ junto a este compose: CSV. mensaje/ puede venir de evolution-manager-v2 vía MENSAJE_PATH.

BULK_API_PORT=8010
DATA_PATH=./data

# Montaje en /app/data/mensaje (msg.txt + .jpg). Por defecto el sibling evolution-manager-v2.
MENSAJE_PATH=../evolution-manager-v2/mensaje

SERVICE_API_KEY=cambia_esta_clave

EVOLUTION_API_URL=https://whatsapp-api.tu-dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=Chinatowm

DELAY_SEG=8
EXTRA_IMAGE_DELAY=2
CSV_FILENAME=grupos_chinatowm.csv

# Orígenes del navegador (obligatorio si la UI está en otro dominio). Varios: separados por coma.
# Ejemplo producción: CORS_ORIGINS=https://sender.jhonocampo.com
# Local: CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Si lo dejas vacío, la API acepta cualquier origen (*), útil solo para pruebas.
# CORS_ORIGINS=https://sender.jhonocampo.com

# Normalmente no hace falta: el contenedor ya usa /app/data
# DATA_DIR=/app/data
# Solo si no montas MENSAJE_PATH y quieres otra ruta dentro del contenedor:
# MSG_DIR=/app/data/mensaje
