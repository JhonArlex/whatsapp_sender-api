# Copiar a .env y ajustar.
#
# Dokploy: Build type = Dockerfile (no Nixpacks/Railpack por defecto; si no, no se usa este Dockerfile).
#   Dockerfile path: Dockerfile   |   Docker context: . (raíz del repo, para COPY data/)
#   Puerto del contenedor: 8010. Volumen en /app/data opcional; si queda vacío, el entrypoint rellena
#   desde la imagen. Tras cambios en data/: redeploy con rebuild.
#
# Datos (este repositorio bulk-sender-api), montados en el contenedor como /app/data:
#   bulk-sender-api/data/<CSV_FILENAME>
#   bulk-sender-api/data/mensaje/msg.txt
#   bulk-sender-api/data/mensaje/*.jpg  y  *.jpeg
# CSV y mensaje no suelen versionarse; la estructura vacía va con .gitkeep en data/.
#
# DATA_PATH: ruta en el host relativa al directorio donde ejecutás docker compose (la raíz del repo).

BULK_API_PORT=8010
DATA_PATH=./data

SERVICE_API_KEY=cambia_esta_clave

EVOLUTION_API_URL=https://whatsapp-api.tu-dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=Chinatowm
# Orígenes contra CORS en Evolution (mismo valor permitido que en Evolution CORS_ORIGIN).
# Evolution hace split por coma SIN espacios: si tienes ", https://" con espacio, puede fallar;
# mejor quita ese espacio en Evolution, o pon aquí varios separados por coma (esta API prueba cada uno):
# EVOLUTION_REQUEST_ORIGIN=https://whatsapp.jhonocampo.com,https://sender.jhonocampo.com,https://sender-api.jhonocampo.com
EVOLUTION_REQUEST_ORIGIN=

DELAY_SEG=8
EXTRA_IMAGE_DELAY=2
CSV_FILENAME=grupos_chinatowm.csv

# Orígenes del navegador (obligatorio si la UI está en otro dominio). Varios: separados por coma.
# Ejemplo producción: CORS_ORIGINS=https://sender.jhonocampo.com
# Local: CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Si lo dejas vacío, la API acepta cualquier origen (*), útil solo para pruebas.
# CORS_ORIGINS=https://sender.jhonocampo.com

# Zona horaria del scheduler (default: Santiago de Chile).
# Santiago usa CLT (UTC-4) en invierno y CLST (UTC-3) en verano.
# Antes se evaluaba contra UTC, lo que causaba desfases si los horarios
# se configuraron pensando en otra zona (ej. España = Europe/Madrid).
# TIMEZONE=America/Santiago

# Cada cuántos segundos el scheduler revisa si los jobs en historial
# han terminado y actualiza su estado (default: 15).
# SCHEDULER_HISTORY_POLL=15

# Conexión a PostgreSQL para schedules, historial y autenticación.
# La base de datos WhatsappSender ya existe con las tablas:
#   api_tokens, schedules, schedule_history
# DATABASE_URL=postgresql://jhonocampo:yMSHGswzRNiu7DmzJ8zN@164.68.109.125:5434/WhatsappSender

# Normalmente no hace falta: el contenedor ya usa /app/data
# DATA_DIR=/app/data
# Copia embebida en imagen (Dockerfile); fallback si no hay msg/CSV en DATA_DIR
# DEFAULT_DATA_DIR=/opt/default-data
# MSG_DIR=
