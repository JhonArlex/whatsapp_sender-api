# Web Sender API - Variables de Entorno
# Copiar a .env y ajustar

# Puerto de la API
BULK_API_PORT=8010
DATA_PATH=./data

# Legacy: API Key para endpoints antiguos
SERVICE_API_KEY=***

# Evolution API
EVOLUTION_API_URL=https://whatsapp-api.tu-dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=default
EVOLUTION_REQUEST_ORIGIN=
DELAY_SEG=8
EXTRA_IMAGE_DELAY=2
CSV_FILENAME=grupos_chinatowm.csv

# CORS (para la UI)
CORS_ORIGINS=https://sender.jhonocampo.com,http://localhost:3010

# Zona horaria
TIMEZONE=America/Bogota

# JWT
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Crypto para API Keys
CRYPTO_KEY=change-this-to-another-random-key-for-encryption

# Conexión PostgreSQL
DATABASE_URL=postgresql://jhonocampo:yMSHGswzRNiu7DmzJ8zN@164.68.109.125:5434/WhatsappSender

# Opcionales
DATA_DIR=/app/data
DEFAULT_DATA_DIR=/opt/default-data
MSG_DIR=
SCHEDULER_CHECK_INTERVAL=30
SCHEDULER_HISTORY_POLL=15
